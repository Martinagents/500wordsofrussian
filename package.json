    "generate:curriculum": "python3 curriculum/scripts/generate_deck.py"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "vite-plugin-pwa": "latest",
    "idb": "latest",
    "ts-fsrs": "latest"
  },
  "devDependencies": {
    "typescript": "latest",
    "vitest": "latest"
  }
}
