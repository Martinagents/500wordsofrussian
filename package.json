{
  "scripts": {
    "dev": "node scripts/build.mjs && python3 -m http.server 5173 -d dist",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "node tests/run-tests.mjs && node tests/runtime-smoke.mjs && node tests/service-worker-smoke.mjs",
